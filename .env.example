# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
REFRESH_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flowboard
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/flowboard

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=flowboard-uploads
SES_FROM_EMAIL=noreply@flowboard.dev

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Postgres (docker-compose only) ───────────────────────────────────────────
POSTGRES_DB=flowboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
