ENVIRONMENT=development
SECRET_KEY=change-me-super-secret-key-at-least-32-characters-long
REFRESH_SECRET_KEY=change-me-refresh-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flowboard
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/flowboard
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
AWS_REGION=us-east-1
S3_BUCKET=flowboard-uploads
SES_FROM_EMAIL=noreply@flowboard.dev
FRONTEND_URL=http://localhost:5173
